# =============================================================================
# AETHER COLLABORATION PLATFORM - Production Environment Variables for Render
# =============================================================================
# Use this as reference when configuring environment variables in Render.com
# DO NOT commit this file with real values to git

# =============================================================================
# GENERAL
# =============================================================================
NODE_ENV=production

# =============================================================================
# API CONFIGURATION (aether-api service)
# =============================================================================
API_PORT=3000

# IMPORTANT: Replace with your actual Render URLs after deployment
CORS_ORIGIN=https://aether-web-xxxxx.onrender.com
ALLOWED_ORIGINS=https://aether-web-xxxxx.onrender.com
FRONTEND_URL=https://aether-web-xxxxx.onrender.com

# =============================================================================
# DATABASE - PostgreSQL (Auto-configured by Render)
# =============================================================================
# These are automatically set by Render when using their PostgreSQL service
DB_HOST=<auto-configured-by-render>
DB_PORT=5432
DB_NAME=aether_production
DB_USER=aether
DB_PASSWORD=<auto-generated-by-render>

# =============================================================================
# REDIS (Auto-configured by Render)
# =============================================================================
# Format: redis://:PASSWORD@aether-redis:6379
# Get the PASSWORD from aether-redis service environment variables
REDIS_URL=redis://:your_redis_password_here@aether-redis:6379

# =============================================================================
# AUTHENTICATION - Auto-generated by Render
# =============================================================================
# Render will auto-generate these - DO NOT set manually
JWT_SECRET=<auto-generated-by-render>
REFRESH_TOKEN_SECRET=<auto-generated-by-render>

# Token expiration times
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# EMAIL SERVICE - Resend
# =============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email configuration
# IMPORTANT: Use a verified domain in Resend
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Aether Platform

# =============================================================================
# FILE UPLOADS
# =============================================================================
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# =============================================================================
# FRONTEND (aether-web service)
# =============================================================================
PORT=3001

# Public variables - Replace with your actual API URL from Render
NEXT_PUBLIC_API_URL=https://aether-api-xxxxx.onrender.com
NEXT_PUBLIC_WS_URL=wss://aether-api-xxxxx.onrender.com

# Telemetry
NEXT_TELEMETRY_DISABLED=1

# PWA (optional)
NEXT_PUBLIC_PWA_ENABLED=false

# =============================================================================
# OPTIONAL - Production Features
# =============================================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# HOW TO USE THIS FILE IN RENDER
# =============================================================================
#
# 1. Go to Render Dashboard
# 2. Select your service (aether-api or aether-web)
# 3. Click "Environment" in the left sidebar
# 4. Add each variable listed above
# 5. Click "Save Changes"
# 6. Render will automatically redeploy with new variables
#
# =============================================================================
# CRITICAL VARIABLES TO SET MANUALLY
# =============================================================================
#
# For aether-api:
#   ✅ RESEND_API_KEY (from resend.com)
#   ✅ CORS_ORIGIN (URL of aether-web after deployment)
#   ✅ ALLOWED_ORIGINS (same as CORS_ORIGIN)
#   ✅ FRONTEND_URL (same as CORS_ORIGIN)
#   ✅ REDIS_URL (with password from aether-redis service)
#   ✅ EMAIL_FROM (verified domain in Resend)
#
# For aether-web:
#   ✅ NEXT_PUBLIC_API_URL (URL of aether-api after deployment)
#   ✅ NEXT_PUBLIC_WS_URL (wss:// version of API URL)
#
# =============================================================================
