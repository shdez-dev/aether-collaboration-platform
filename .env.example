# =============================================================================
# AETHER COLLABORATION PLATFORM - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real credentials to git

# =============================================================================
# GENERAL
# =============================================================================
NODE_ENV=development # development | staging | production

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_PORT=3000
CORS_ORIGIN=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
FRONTEND_URL=http://localhost:3001

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aether_dev
DB_USER=aether
DB_PASSWORD=your_secure_password_here

# Connection string (alternative to individual variables)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION
# =============================================================================
# IMPORTANT: Generate strong random secrets for production!
# Use: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_change_in_production

# Token expiration times
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# EMAIL SERVICE
# =============================================================================
# Using Resend for transactional emails
RESEND_API_KEY=re_your_resend_api_key_here

# Email configuration
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Aether Platform

# =============================================================================
# FILE UPLOADS
# =============================================================================
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880 # 5MB in bytes

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================
# Public variables (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_PWA_ENABLED=false

# Private variables (server-side only)
PORT=3001

# =============================================================================
# OPTIONAL - Advanced Features
# =============================================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (when implemented)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=your_datadog_api_key

# Logging
LOG_LEVEL=info # debug | info | warn | error
LOG_FORMAT=json # json | pretty

# =============================================================================
# PRODUCTION SPECIFIC
# =============================================================================
# Uncomment and configure for production deployment

# SSL/HTTPS
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Security
# HELMET_CSP_ENABLED=true
# TRUSTED_PROXY=true

# Scaling
# CLUSTER_MODE=true
# CLUSTER_WORKERS=4
